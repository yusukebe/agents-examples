{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "schedule-tasks",
  "main": "./src/index.ts",
  "compatibility_date": "2026-07-06",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "ScheduleAgent",
        "class_name": "ScheduleAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ScheduleAgent"]
    }
  ]
}
