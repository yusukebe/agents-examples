{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-chat",
  "main": "./src/index.tsx",
  "compatibility_date": "2026-07-06",
  "compatibility_flags": ["nodejs_compat"],
  "ai": { "binding": "AI" },
  "durable_objects": {
    "bindings": [{ "name": "ChatAgent", "class_name": "ChatAgent" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["ChatAgent"] }]
}
